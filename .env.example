# ── 复制此文件为 backend/.env（本地开发用）──────────────────────────

# JWT 签名密钥，随便填一串随机字符串
SECRET_KEY=your-super-secret-key-change-this

# 管理员账号（首次启动自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── PostgreSQL 连接 ───────────────────────────────────────────────────
# 本地开发：填下面这几项
DB_HOST=localhost
DB_PORT=5432
DB_USER=oci
DB_PASSWORD=oci123
DB_NAME=oci_manager

# 自动建库需要一个有 CREATEDB 权限的超级用户
# 本地 PostgreSQL 默认超级用户是 postgres，密码看你安装时设置的
PG_ROOT_USER=postgres
PG_ROOT_PASSWORD=postgres

# ── Docker 部署额外用到 ───────────────────────────────────────────────
# 前端 Nginx 对外暴露的端口（只有 docker-compose 用，本地开发无效）
PORT=8080
